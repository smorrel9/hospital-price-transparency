{
  "name": "hospital-price-transparency",
  "version": "0.1.0",
  "type": "module",
  "description": "Transform CMS-mandated hospital pricing files into a searchable, consumer-friendly interface",
  "main": "src/server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node src/server.js",
    "client": "vite",
    "build": "vite build",
    "fetch-data": "node scripts/fetch-data.js",
    "parse-data": "node scripts/parse-csv.js",
    "parse-json": "node scripts/parse-json.js",
    "seed-db": "node scripts/seed-db.js",
    "build-names": "node scripts/build-friendly-names.js",
    "setup": "npm run fetch-data && npm run parse-data && npm run seed-db && npm run build-names"
  },
  "keywords": [
    "healthcare",
    "price-transparency",
    "CMS",
    "hospital-pricing",
    "consumer-health"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "stream-json": "^2.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.0",
    "postcss": "^8.5.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0"
  }
}
